{
  "name": "presscare/presscare-ai-error-doctor",
  "description": "Read-only WordPress error diagnostics with privacy-first, provider-independent AI explanations.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Kevin Kemp - PressCare",
      "homepage": "https://presscare.com"
    }
  ],
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpunit/phpunit": "^9.6 || ^10.5 || ^11.0",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "autoload": {
    "psr-4": {
      "PressCare\\AIErrorDoctor\\": "src/"
    }
  },
  "scripts": {
    "lint": "phpcs",
    "smoke": "php tests/smoke.php",
    "test": [
      "@smoke",
      "phpunit"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  }
}
